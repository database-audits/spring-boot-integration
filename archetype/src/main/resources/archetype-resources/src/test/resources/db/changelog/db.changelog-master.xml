<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Clean demo schema: every base table has a primary key; the foreign key is not-null, type-matched, and
         indexed; the name column is indexed; no index is a leading prefix of another. Catalog audits return empty. -->

    <changeSet id="1-create-parent" author="database-audits">
        <createTable tableName="parent">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_parent" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_parent_code" tableName="parent">
            <column name="code"/>
        </createIndex>
    </changeSet>

    <changeSet id="2-create-child" author="database-audits">
        <createTable tableName="child">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_child" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="parent_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_child_parent"
                    referencedTableName="parent" referencedColumnNames="id"/>
            </column>
        </createTable>
        <createIndex indexName="idx_child_parent_id" tableName="child">
            <column name="parent_id"/>
        </createIndex>
        <createIndex indexName="idx_child_name" tableName="child">
            <column name="name"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
