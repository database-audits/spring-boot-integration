<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor
    xmlns="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0 https://maven.apache.org/xsd/archetype-descriptor-1.1.0.xsd"
    name="database-audits-spring-boot">

  <requiredProperties>
    <!-- project generates the full demo harness (current behavior); tests-only generates only the audit
         test classes (the harness files are removed by the post-generate script). -->
    <requiredProperty key="generateMode">
      <defaultValue>project</defaultValue>
    </requiredProperty>
    <!-- The schema the catalog audits scan (read by the example ITs via @Value). -->
    <requiredProperty key="schemaName">
      <defaultValue>public</defaultValue>
    </requiredProperty>
    <!-- The Spring property key the catalog ITs read via @Value to obtain the schema name. -->
    <requiredProperty key="schemaPropertyName">
      <defaultValue>database.datasource.schema-name</defaultValue>
    </requiredProperty>
    <!-- Optional. Fully qualified name of a base class for AbstractDatabaseAuditIT to extend.
         Default 'none' means no explicit parent. Override with a real class to add extends + import. -->
    <requiredProperty key="parentClass">
      <defaultValue>none</defaultValue>
    </requiredProperty>
    <!-- Version of the database-audits Spring Boot integration the generated project depends on. -->
    <requiredProperty key="databaseAuditsVersion">
      <defaultValue>1.0.0</defaultValue>
    </requiredProperty>
    <!-- Spring Boot parent version of the generated project. -->
    <requiredProperty key="springBootVersion">
      <defaultValue>4.1.0</defaultValue>
    </requiredProperty>
    <!-- The database engine the generated demo harness targets: postgresql (default), mysql, or mariadb. It drives
         the Testcontainers container and JDBC driver the harness uses and which runtime audit ITs are generated —
         the plan-based audits (Join/OrderBy/WhereClause index) are PostgreSQL-only, so they are generated for
         postgresql only; the catalog, JPA, and unconditional-mutation audits are generated for every engine. -->
    <requiredProperty key="databasePlatform">
      <defaultValue>postgresql</defaultValue>
    </requiredProperty>
    <!-- The container image the demo harness starts, overriding the per-platform default (postgres:16, mysql:8, or
         mariadb:11). Default 'none' selects that per-platform default; set it to pin a specific image tag. -->
    <requiredProperty key="databaseImage">
      <defaultValue>none</defaultValue>
    </requiredProperty>
    <!-- When 'true', every generated test is annotated with JUnit's @Disabled, so the suite is generated and
         compiles but does not run. SchemaEntityValidationAuditIT is annotated on the class (not the method) so
         its Spring context never loads. Default 'false' runs the audits. Useful for scaffolding
         the suite into a project that does not pass it yet, then enabling audits one at a time. -->
    <requiredProperty key="disabledTests">
      <defaultValue>false</defaultValue>
    </requiredProperty>
    <!-- The consolidated audit report's format, written by the auto-registered report listener when a run has
         findings: asciidoc (default), markdown, or text. Seeded into the generated junit-platform.properties as
         database-audits.report.format. -->
    <requiredProperty key="reportFormat">
      <defaultValue>asciidoc</defaultValue>
    </requiredProperty>
    <!-- The remediation the report emits for each finding: liquibase-xml (default; a databaseChangeLog fragment),
         sql (raw DDL), or none (findings only). Seeded as database-audits.report.fix-format. -->
    <requiredProperty key="fixFormat">
      <defaultValue>liquibase-xml</defaultValue>
    </requiredProperty>
    <!-- Where the report places each audit's fixes: both (default; inline under each audit and in a consolidated
         section), inline, or section. Seeded as database-audits.report.fix-placement. -->
    <requiredProperty key="fixPlacement">
      <defaultValue>both</defaultValue>
    </requiredProperty>
    <!-- The datasource to audit when the application configures several peer datasources with no @Primary.
         When set (not 'none'), the post-generate script expands the token config template into a
         DatabaseAudit<Name>TestConfiguration that resolves this datasource's beans by @Qualifier, and each audit IT
         @Imports it. The value labels the generated config class (Pascal-cased) and its SQL capturer bean
         (camel-cased), so it must be a valid Java identifier. Default 'none' (a non-empty sentinel, like
         parentClass, so the integration-test mojo does not treat it as missing) generates the single-datasource
         suite that imports the stock DatabaseAuditTestConfiguration. -->
    <requiredProperty key="dataSourceName">
      <defaultValue>none</defaultValue>
    </requiredProperty>
    <!-- The DataSource bean name the generated per-datasource config resolves by @Qualifier. Required (not 'none')
         when dataSourceName is set; ignored otherwise. -->
    <requiredProperty key="dataSourceBeanName">
      <defaultValue>none</defaultValue>
    </requiredProperty>
    <!-- The EntityManagerFactory bean name the generated per-datasource config resolves by @Qualifier. Required
         (not 'none') when dataSourceName is set; ignored otherwise. -->
    <requiredProperty key="entityManagerFactoryBeanName">
      <defaultValue>none</defaultValue>
    </requiredProperty>
  </requiredProperties>

  <fileSets>
    <!-- Audit IT sources: filtered (so ${package} resolves) and placed under the consumer package. -->
    <fileSet filtered="true" packaged="true" encoding="UTF-8">
      <directory>src/test/java</directory>
      <includes>
        <include>**/*.java</include>
      </includes>
    </fileSet>
    <!-- Test resources: filtered (so ${schemaName} resolves) but not under the package. -->
    <fileSet filtered="true" packaged="false" encoding="UTF-8">
      <directory>src/test/resources</directory>
      <includes>
        <include>**/*.properties</include>
        <include>**/*.xml</include>
      </includes>
    </fileSet>
  </fileSets>
</archetype-descriptor>
